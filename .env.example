# Public base URL of the gateway (Railway domain), no trailing slash
PUBLIC_URL=https://heimdall.up.railway.app
PORT=3000

# Linear OAuth app (linear.app/settings/api/applications)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# GitHub auth: either a GitHub App (recommended) ...
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# ... or a classic PAT with repo scope (personal fallback)
GITHUB_PAT=

# Shared secret between gateway and the runner workflow (also set as an Actions secret)
HEIMDALL_CALLBACK_SECRET=

# Linear team key -> owner/repo; "*" is the catch-all
HEIMDALL_ROUTES={"ENG":"acme/backend","*":"viniciussouza/sandbox"}

# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
