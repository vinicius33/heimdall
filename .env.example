# Public base URL of the gateway, no trailing slash
PUBLIC_URL=https://heimdall.example.com
PORT=3000

# Linear OAuth app (linear.app/settings/api/applications)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# GitHub auth: either a GitHub App (recommended) ...
GITHUB_APP_ID=
# Paste the .pem as ONE line, newlines escaped as \n (the config unescapes them), e.g.:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEog...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=
# ... or a classic PAT with repo scope (personal fallback; unused while App creds are set)
GITHUB_PAT=

# Shared secret between gateway and the runner workflow (also set as an Actions secret)
HEIMDALL_CALLBACK_SECRET=

# Linear team key -> owner/repo; "*" is the catch-all team.
HEIMDALL_ROUTES={"ENG":"acme/backend","*":"acme/sandbox"}
# Serving multiple Linear workspaces? Nest tables under workspace (organization) ids;
# the id is printed on the OAuth install success page; "*" is the catch-all workspace:
# HEIMDALL_ROUTES={"9f1e...org-id":{"ENG":"acme/backend"},"*":{"*":"acme/sandbox"}}

# Redis: set ONE of the two options.
# a) Plain TCP Redis (e.g. a managed Redis instance or the bundled docker-compose service)
REDIS_URL=
# b) Upstash REST (only needed if the gateway ever moves to CF Workers/Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
